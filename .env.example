# Copy to .env and set a strong random token before running compose.
PROXYTAVERN_ENV=prod
PROXYTAVERN_AUTH_ENABLED=true
PROXYTAVERN_BEARER_TOKEN=replace-with-long-random-token
PROXYTAVERN_DB_PATH=/data/proxytavern.db

# LAN hardening default: loopback-only bind. For LAN expose, set host IP explicitly.
PROXYTAVERN_BIND=127.0.0.1
PROXYTAVERN_PORT=8080
